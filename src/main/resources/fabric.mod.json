{
  "schemaVersion": 1,
  "id": "pca-client",
  "version": "${version}",
  "name": "PCA Client",
  "description": "轻量 PCA 同步协议客户端，配合服务端 carpet-pls-addition 实现 Tweakeroo 多人容器预览",
  "authors": [
    "RisingZenByte"
  ],
  "contact": {
    "homepage": "https://github.com/RisingZenByte/pca-client",
    "issues": "https://github.com/RisingZenByte/pca-client/issues",
    "sources": "https://github.com/RisingZenByte/pca-client"
  },
  "license": "LGPL-3.0",
  "environment": "client",
  "entrypoints": {
    "client": [
      "pls.pca.client.PcaClientMod"
    ]
  },
  "mixins": [
    "pca-client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "${minecraft_dependency}",
    "fanetlib": ">=0.2.0"
  },
  "suggests": {
    "tweakeroo": "*",
    "malilib": "*"
  },
  "breaks": {
    "pca-protocol": "*",
    "masagadget": "*"
  }
}
